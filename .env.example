# --- Required ---
# Anthropic API key (for /summary). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Shared secret you generate; required as `Authorization: Bearer <token>` on /top, /summary, /ingest
API_TOKEN=change-me-to-a-long-random-string

# --- Storage ---
# SQLite path. On Railway, point this at a mounted volume, e.g. /data/hnbot.db
DB_PATH=./hnbot.db

# --- Feed / window tuning ---
WINDOW_DAYS=7
SUMMARY_DAYS=3
SUMMARY_LIMIT=40
SUMMARY_MODEL=claude-sonnet-4-6

# --- Per-story article summaries (history corpus + what the digest synthesizes) ---
# Model for the single-paragraph per-article summaries
STORY_SUMMARY_MODEL=claude-sonnet-5
# Only summarize stories whose peak score reaches this
SUMMARY_MIN_SCORE=150
# Bounds cost/latency per poll
STORY_SUMMARY_MAX_PER_POLL=20
STORY_SUMMARY_CONCURRENCY=4
STORY_SUMMARY_MAX_ATTEMPTS=3
# Max characters of extracted article text fed to the model
ARTICLE_MAX_CHARS=8000
# Top HN comments included per story
COMMENTS_PER_STORY=6
ARTICLE_FETCH_TIMEOUT_MS=12000

# --- Scheduling (cron expressions) ---
POLL_CRON=0 */2 * * *
CLEANUP_CRON=17 3 * * *
FETCH_CONCURRENCY=15

# --- Server ---
PORT=8080

# --- Telegram (optional; leave TELEGRAM_BOT_TOKEN empty to disable) ---
# Token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=
# Public base URL of this service, used to register the webhook (no trailing slash).
# On Railway this is auto-derived from RAILWAY_PUBLIC_DOMAIN if unset.
PUBLIC_URL=https://hnbot-production.up.railway.app
# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Leave empty for open mode; set it (your own id) to lock the bot to you.
TELEGRAM_ALLOWED_USER_IDS=
# Stories per message (daily send and each "More stories" tap)
TELEGRAM_STORIES=8
# Schedule (cron, evaluated in TELEGRAM_TZ)
TELEGRAM_TZ=Europe/Berlin
TELEGRAM_DAILY_CRON=0 8 * * *
TELEGRAM_SUMMARY_CRON=0 8 * * 2,5
